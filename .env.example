# === Mistral AI ===
# Obtenez votre clé sur https://console.mistral.ai (La Plateforme)
MISTRAL_API_KEY=changez_moi

# === Modèles (valeurs par défaut) ===
CHAT_MODEL=mistral-small-latest
EMBEDDING_MODEL=mistral-embed
TEMPERATURE=0.1

# === Paramètres RAG ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4
COLLECTION_NAME=documents

# === Application ===
APP_ENV=development
LOG_LEVEL=INFO
